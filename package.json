{
  "name": "@scoope/sdk",
  "version": "0.1.0",
  "description": "Official TypeScript client for Scoope — the policy-enforcement gateway for AI agents.",
  "license": "Apache-2.0",
  "author": "Thundered Studios",
  "homepage": "https://scoope.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/thundered/scoope-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/thundered/scoope-sdk/issues"
  },
  "keywords": [
    "scoope",
    "ai",
    "agent",
    "policy",
    "gateway",
    "permissions",
    "llm",
    "mcp",
    "audit"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "prepublishOnly": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "msw": "^2.6.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
